{
  "name": "copilot-typescript-tutorial",
  "version": "1.0.0",
  "description": "GitHub Copilot tutorial examples for TypeScript",
  "main": "dist/express-api.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/express-api.js",
    "dev": "ts-node express-api.ts",
    "dev:watch": "nodemon --exec ts-node express-api.ts",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "lint": "eslint **/*.ts"
  },
  "keywords": ["github-copilot", "typescript", "tutorial", "express", "api", "type-safe"],
  "author": "GitHub Copilot Tutorial",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "@types/node": "^20.4.5",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.4",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.3",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.45.0",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1"
  }
}